# ─── Plaid API Keys ───────────────────────────────────────────────────────────
# Get these from https://dashboard.plaid.com/developers/keys
PLAID_CLIENT_ID=your_client_id_here
PLAID_SECRET=your_sandbox_secret_here

# Environment: sandbox | development | production
# Use 'sandbox' for testing (no real bank), 'development' for up to 100 live accounts
PLAID_ENV=sandbox

# ─── App ──────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins (your Netlify domain)
ALLOWED_ORIGINS=https://your-app.netlify.app,http://localhost:5173
